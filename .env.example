# OpenTelemetry Collector OTLP endpoint for exporting traces and metrics
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# SigNoz MCP server endpoint for querying observability data
SIGNOZ_MCP_ENDPOINT=http://localhost:8080/mcp

# API key for the LLM provider (e.g., OpenAI, Anthropic)
LLM_API_KEY=sk-placeholder-key-replace-me

# Model name to use for LLM inference
LLM_MODEL_NAME=gpt-4o

# GitHub personal access token for repository operations
GITHUB_TOKEN=ghp_placeholder_token_replace_me

# GitHub repository in owner/repo format
GITHUB_REPO=your-org/your-repo

# Slack incoming webhook URL for incident notifications
SLACK_WEBHOOK_URL